# ===========================
# Anthropic Claude API
# ===========================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================
# Gmail SMTP (App Password)
# ===========================
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an app password for "Mail" / "Other"
# 4. Paste the 16-character app password below (no spaces)
GMAIL_APP_PASSWORD=your_16_char_app_password_here
GMAIL_FROM=yaseenkadlemakki@gmail.com
GMAIL_TO=yaseenkadlemakki@gmail.com

# ===========================
# Database (optional override)
# ===========================
# DATABASE_URL=sqlite:///./data/job_hunter.db
# For PostgreSQL (cloud deployment):
# DATABASE_URL=postgresql://user:password@host:5432/job_hunter

# ===========================
# LinkedIn Credentials (optional, for authenticated search)
# ===========================
# LINKEDIN_EMAIL=your_linkedin_email@example.com
# LINKEDIN_PASSWORD=your_linkedin_password

# ===========================
# App Settings
# ===========================
LOG_LEVEL=INFO
ENV=development
